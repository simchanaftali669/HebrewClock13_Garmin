        (:initialized) var mazal_eng_4 as Symbol;
        (:initialized) var mazal_heb_6 as Symbol;
        (:initialized) var mazal_eng_3 as Symbol;
        (:initialized) var HomeTitle as Symbol;
        (:initialized) var mazal_eng_7 as Symbol;
        (:initialized) var AppName as Symbol;
        (:initialized) var menuEng_label_1 as Symbol;
        (:initialized) var menuEng_label_2 as Symbol;
        (:initialized) var MenuLabel1 as Symbol;
